# Build artifacts (root-level binaries; anchored with / so the pattern
# does NOT also match the cmd/gorefactor/ source dir — an unanchored
# "gorefactor" gitignores every untracked file under cmd/gorefactor/)
/gorefactor
/skill-refactor
*.exe
*.dll
*.so
*.dylib

# Runtime snapshots and state
.gorefactor/

# Generated templates (created by generate-templates command)
test_templates/
templates/
generated_templates/

# User-generated refactoring plans
user_plans/
refactoring_plans/
plans/

# Execution results
results/
execution_results/
*.results.json

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Go specific
*.test
*.out
coverage.html
go.work

# Temporary files
*.tmp
*.temp

# Build artifacts (root-level binaries)
/gorefactor-agent

# Benchmark runner binary
/benchmark/benchmark_runner

# Claude Code agent worktrees (ephemeral)
.claude/worktrees/
