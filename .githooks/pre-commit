#!/bin/bash
# Pre-commit hook — the doctor gate: formats, then runs lint + build + test via
# `gorefactor doctor`. This is the safety net: even if an editor/agent used a
# native Edit instead of a gorefactor command, broken Go is caught here before
# it can be committed. Bypass a single commit with `git commit --no-verify`.

set -e

echo "Running pre-commit checks..."

if ! command -v make &> /dev/null; then
    echo "⚠ Make not found. Skipping pre-commit checks."
    exit 0
fi

# Format first (doctor does not format).
echo "Checking code formatting..."
make fmt 2>/dev/null || echo "⚠ Format check failed (continuing)"

# Doctor gate: builds gorefactor, then lint + build + test. Blocks on failure.
echo "Running gorefactor doctor (lint + build + test)..."
make gate || {
    echo "✗ doctor gate failed. Run 'make gate' to see issues, or 'git commit --no-verify' to bypass."
    exit 1
}

echo "✓ Pre-commit checks passed"
exit 0
